APP_NAME=Network Monitoring
APP_ENV=production
MYSQL_DATABASE=network_monitoring
MYSQL_USER=network_monitoring
MYSQL_PASSWORD=replace-with-a-strong-password
MYSQL_ROOT_PASSWORD=replace-with-a-separate-strong-root-password

DATABASE_URL=mysql+pymysql://network_monitoring:replace-with-a-strong-password@localhost:3306/network_monitoring
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MIKROTIK_HOST=
MIKROTIK_USERNAME=
MIKROTIK_PASSWORD=
DASHBOARD_API_URL=http://localhost:8000
TRUSTED_HOSTS=api.example.com,dashboard.example.com
TRUSTED_PROXY_IPS=10.0.0.10
CORS_ORIGINS=https://dashboard.example.com
AUTH_TOKEN_TTL_MINUTES=720
AUTH_REMEMBER_TTL_MINUTES=10080
AUTH_JWT_SECRET=replace-with-a-long-random-jwt-secret
# Production-only file-backed secret override (aktifkan di APP_ENV=production)
# AUTH_JWT_SECRET_FILE=/run/secrets/auth_jwt_secret
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_SESSION_TOUCH_INTERVAL_SECONDS=300
AUTH_SESSION_RETENTION_DAYS=30
AUTH_LOGIN_ATTEMPT_RETENTION_DAYS=7
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_FULL_NAME=Monitoring Admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
# BOOTSTRAP_ADMIN_PASSWORD_FILE=/run/secrets/bootstrap_admin_password
PING_TIMEOUT_SECONDS=2
PING_SAMPLE_COUNT=3
MONITOR_TASK_CONCURRENCY_LIMIT=16
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_INTERNET_SECONDS=30
SCHEDULER_INTERVAL_DEVICE_SECONDS=60
SCHEDULER_INTERVAL_SERVER_SECONDS=60
SCHEDULER_INTERVAL_MIKROTIK_SECONDS=60
SCHEDULER_INTERVAL_ALERT_SECONDS=30
MONITORING_LOCK_NAME=network_monitoring.pipeline
MONITORING_LOCK_TIMEOUT_SECONDS=900
DNS_CHECK_HOST=google.com
HTTP_CHECK_URL=https://www.google.com/generate_204
PUBLIC_IP_CHECK_URL=https://api.ipify.org
RAW_METRIC_RETENTION_DAYS=7
ALERT_RETENTION_DAYS=180
INCIDENT_RETENTION_DAYS=180
SCHEDULER_CLEANUP_INTERVAL_HOURS=24
CPU_WARNING_THRESHOLD=90
RAM_WARNING_THRESHOLD=90
DISK_WARNING_THRESHOLD=85
SERVER_RESOURCE_DEVICE_IP=
INTERNAL_API_KEY=replace-with-a-long-random-api-key
# INTERNAL_API_KEY_FILE=/run/secrets/internal_api_key
INTERNAL_API_KEYS=
AUTH_PASSWORD_SECRET=replace-with-a-long-random-password-secret
# AUTH_PASSWORD_SECRET_FILE=/run/secrets/auth_password_secret
AUTH_PASSWORD_MIN_LENGTH=12
ALLOW_INSECURE_NO_AUTH=false
PRINTER_SNMP_COMMUNITIES={"192.168.88.38":"community-printer-1","192.168.88.145":"community-printer-2"}
LOG_LEVEL=INFO
LOG_AS_JSON=true
OBSERVABILITY_ENABLE_METRICS=true
REQUEST_SLOW_LOG_THRESHOLD_MS=1000
PROMETHEUS_MULTIPROC_DIR=/tmp/network_monitoring_prometheus
SCHEDULER_JOB_STALE_FACTOR=3
