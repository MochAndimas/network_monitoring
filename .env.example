# Copy this file to `.env`, then choose one APP_ENV value.
# Development: local host or local Docker Compose.
# Production: deployed host with real domains, HTTPS, strong secrets, and Alembic migrations.

# App environment
APP_NAME=Network Monitoring
APP_ENV=development

# Database
MYSQL_DATABASE=network_monitoring
MYSQL_USER=network_monitoring
MYSQL_PASSWORD=replace-with-a-local-password
MYSQL_ROOT_PASSWORD=replace-with-a-local-root-password
DATABASE_URL=mysql+pymysql://network_monitoring:replace-with-a-local-password@localhost:3306/network_monitoring
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# Backend/dashboard URLs
DASHBOARD_API_URL=http://localhost:8000
DASHBOARD_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
TRUSTED_HOSTS=localhost,127.0.0.1
TRUSTED_PROXY_IPS=

# Auth and API keys
INTERNAL_API_KEY=dev-internal-key
INTERNAL_API_KEYS=
AUTH_PASSWORD_SECRET=dev-password-secret-change-me
AUTH_TOKEN_TTL_MINUTES=30
AUTH_REMEMBER_TTL_MINUTES=10080
AUTH_JWT_SECRET=dev-jwt-secret-change-me
AUTH_JWT_ISSUER=network-monitoring
AUTH_JWT_ALGORITHM=HS256
AUTH_COOKIE_NAME=network_monitoring_session
AUTH_REFRESH_COOKIE_NAME=network_monitoring_refresh
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_SESSION_TOUCH_INTERVAL_SECONDS=300
AUTH_SESSION_RETENTION_DAYS=30
AUTH_LOGIN_ATTEMPT_RETENTION_DAYS=7
AUTH_PASSWORD_MIN_LENGTH=12
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_FULL_NAME=Monitoring Admin
BOOTSTRAP_ADMIN_PASSWORD=dev-admin-password-change-me
ALLOW_INSECURE_NO_AUTH=false

# Production-only file-backed secret overrides.
# These are allowed only when APP_ENV=production.
# TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
# TELEGRAM_CHAT_ID_FILE=/run/secrets/telegram_chat_id
# MIKROTIK_PASSWORD_FILE=/run/secrets/mikrotik_password
# INTERNAL_API_KEY_FILE=/run/secrets/internal_api_key
# AUTH_PASSWORD_SECRET_FILE=/run/secrets/auth_password_secret
# PRINTER_SNMP_COMMUNITIES_FILE=/run/secrets/printer_snmp_communities
# BOOTSTRAP_ADMIN_PASSWORD_FILE=/run/secrets/bootstrap_admin_password
# AUTH_JWT_SECRET_FILE=/run/secrets/auth_jwt_secret

# Monitoring integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MIKROTIK_HOST=
MIKROTIK_PORT=8728
MIKROTIK_USERNAME=
MIKROTIK_PASSWORD=
SERVER_RESOURCE_DEVICE_IP=
PRINTER_SNMP_COMMUNITIES={"192.168.88.38":"community-printer-1","192.168.88.145":"community-printer-2"}

# Mikrotik dynamic metrics
MIKROTIK_DYNAMIC_SECTIONS=interface,firewall,queue
MIKROTIK_DYNAMIC_FIREWALL_SECTION_ALLOWLIST=filter,nat
MIKROTIK_DYNAMIC_INTERFACE_ALLOWLIST=
MIKROTIK_DYNAMIC_QUEUE_ALLOWLIST=
MIKROTIK_DYNAMIC_MAX_INTERFACES=64
MIKROTIK_DYNAMIC_MAX_FIREWALL_RULES=128
MIKROTIK_DYNAMIC_MAX_QUEUES=64

# Scheduler and checks
PING_TIMEOUT_SECONDS=2
PING_SAMPLE_COUNT=3
PING_CONCURRENCY_LIMIT=32
MONITOR_TASK_CONCURRENCY_LIMIT=16
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_INTERNET_SECONDS=30
SCHEDULER_INTERVAL_DEVICE_SECONDS=60
SCHEDULER_INTERVAL_SERVER_SECONDS=60
SCHEDULER_INTERVAL_MIKROTIK_SECONDS=60
SCHEDULER_INTERVAL_ALERT_SECONDS=30
SCHEDULER_JOB_MAX_INSTANCES=1
MONITORING_LOCK_NAME=network_monitoring.pipeline
MONITORING_LOCK_TIMEOUT_SECONDS=900
DNS_CHECK_HOST=google.com
HTTP_CHECK_URL=https://www.google.com/generate_204
PUBLIC_IP_CHECK_URL=https://api.ipify.org

# Retention and observability
RAW_METRIC_RETENTION_DAYS=7
RETENTION_ROLLUP_BATCH_SIZE=500
RETENTION_ARCHIVE_BATCH_SIZE=500
ALERT_RETENTION_DAYS=180
INCIDENT_RETENTION_DAYS=180
SCHEDULER_CLEANUP_INTERVAL_HOURS=24
SCHEDULER_JOB_STALE_FACTOR=3
OBSERVABILITY_ENABLE_METRICS=true
LOG_AS_JSON=true
LOG_LEVEL=INFO
REQUEST_SLOW_LOG_THRESHOLD_MS=1000
PROMETHEUS_MULTIPROC_DIR=/tmp/network_monitoring_prometheus
CPU_WARNING_THRESHOLD=90
RAM_WARNING_THRESHOLD=90
DISK_WARNING_THRESHOLD=85

# Production overrides checklist:
# APP_ENV=production
# DATABASE_URL=mysql+pymysql://network_monitoring:replace-with-a-strong-password@mysql-or-db-host:3306/network_monitoring
# DASHBOARD_API_URL=http://backend:8000
# DASHBOARD_PUBLIC_API_URL=https://dashboard.example.com
# CORS_ORIGINS=https://dashboard.example.com
# TRUSTED_HOSTS=api.example.com,dashboard.example.com
# TRUSTED_PROXY_IPS=10.0.0.10
# INTERNAL_API_KEY=replace-with-a-long-random-api-key
# AUTH_PASSWORD_SECRET=replace-with-a-long-random-password-secret
# AUTH_TOKEN_TTL_MINUTES=720
# AUTH_JWT_SECRET=replace-with-a-long-random-jwt-secret
# AUTH_COOKIE_SECURE=true
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
# LOG_AS_JSON=true
